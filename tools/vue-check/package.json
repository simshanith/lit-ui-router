{
  "name": "vue-check",
  "version": "0.0.1",
  "private": true,
  "description": "Typechecks a workspace package's Vue SFCs with vue-tsc, which embeds the TypeScript 6 API",
  "bin": {
    "vue-check": "./bin.ts"
  },
  "type": "module",
  "scripts": {
    "format": "oxfmt \"**/*.{ts,js,json,md}\"",
    "format:check": "oxfmt --check \"**/*.{ts,js,json,md}\"",
    "lint": "oxlint ."
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vue-tsc": "catalog:"
  }
}
