{
  "name": "@tools/build_and_test",
  "version": "0.0.1",
  "private": true,
  "description": "Owns the build-test workflow's step logic: the shared Xvfb display and the Codecov bundle-stats upload",
  "bin": {
    "start-xvfb": "./src/start-xvfb.ts",
    "upload-bundle-stats": "./src/upload-bundle-stats.ts"
  },
  "type": "module",
  "scripts": {
    "format": "oxfmt \"**/*.{ts,js,json,jsonc,md}\"",
    "format:check": "oxfmt --check \"**/*.{ts,js,json,jsonc,md}\"",
    "lint": "oxlint .",
    "test": "node --test \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@codecov/bundle-analyzer": "catalog:",
    "@types/node": "catalog:",
    "cypress": "catalog:",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
