{
  "name": "typedoc-plugin-lit-ui-router",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./kind-indexes": {
      "types": "./dist/kind-indexes.d.ts",
      "default": "./dist/kind-indexes.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "format": "oxfmt \"**/*.{ts,js,json,md}\"",
    "format:check": "oxfmt --check \"**/*.{ts,js,json,md}\"",
    "lint": "oxlint ."
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typedoc": "catalog:",
    "typescript": "catalog:typescript6-compat"
  },
  "peerDependencies": {
    "typedoc": "catalog:publishedPeer"
  }
}
