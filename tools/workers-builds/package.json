{
  "name": "workers-builds",
  "version": "0.0.1",
  "private": true,
  "description": "Diffs the Cloudflare Workers Builds triggers against the repo-owned desired state, and applies it",
  "type": "module",
  "scripts": {
    "check": "node workers-builds-triggers.ts",
    "format": "oxfmt \"**/*.{ts,js,json,jsonc,md}\"",
    "format:check": "oxfmt --check \"**/*.{ts,js,json,jsonc,md}\"",
    "lint": "oxlint .",
    "test": "node --test workers-builds-triggers.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "jsonc-parser": "catalog:",
    "typescript": "catalog:"
  }
}
