{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vitepress build .",
    "docs": "vitepress dev .",
    "docs:preview": "vitepress preview .",
    "format": "oxfmt \"**/*.{md,json,ts,vue}\"",
    "format:check": "oxfmt --check \"**/*.{md,json,ts,vue}\"",
    "lint": "oxlint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:vue": "vue-check docs/tsconfig.vue.json",
    "typecheck:worker": "tsc -p worker/tsconfig.json --noEmit",
    "types:worker": "wrangler types worker/worker-configuration.d.ts",
    "wrangler:dev": "wrangler dev"
  },
  "dependencies": {
    "@spectrum-web-components/icons-workflow": "catalog:",
    "sample-app-lit-mobx": "workspace:*",
    "sample-app-lit-vanilla": "workspace:*",
    "sample-app-routes": "workspace:*",
    "screenfull": "catalog:",
    "ui-router-server": "workspace:*",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@tools/vue-check": "workspace:*",
    "oxfmt": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-static-copy": "catalog:vitepress1",
    "vitepress": "catalog:",
    "wrangler": "catalog:"
  }
}
