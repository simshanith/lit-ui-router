{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vitepress build .",
    "docs": "vitepress dev .",
    "docs:preview": "vitepress preview .",
    "format": "prettier --write \"**/*.{md,json,ts}\"",
    "format:check": "prettier --check \"**/*.{md,json,ts}\"",
    "lint": "oxlint .",
    "wrangler": "wrangler --config ../wrangler.jsonc",
    "wrangler:dev": "pnpm run wrangler dev"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-static-copy": "catalog:vitepress1",
    "vitepress": "^1.6.4",
    "wrangler": "catalog:"
  },
  "dependencies": {
    "@spectrum-web-components/icons-workflow": "^1.12.1",
    "sample-app-lit-mobx": "workspace:*",
    "sample-app-lit-vanilla": "workspace:*",
    "screenfull": "^6.0.2",
    "vue": "^3.5.39"
  }
}
