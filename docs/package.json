{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vitepress build .",
    "docs": "vitepress dev .",
    "docs:preview": "vitepress preview .",
    "format": "oxfmt \"**/*.{md,json,ts,vue}\"",
    "format:check": "oxfmt --check \"**/*.{md,json,ts,vue}\"",
    "lint": "oxlint .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p worker/tsconfig.json --noEmit",
    "typecheck:vue": "vue-check docs/tsconfig.vue.json",
    "wrangler:dev": "wrangler dev"
  },
  "dependencies": {
    "@spectrum-web-components/icons-workflow": "^1.12.1",
    "sample-app-lit-mobx": "workspace:*",
    "sample-app-lit-vanilla": "workspace:*",
    "sample-app-shared": "workspace:*",
    "screenfull": "^6.0.2",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "oxfmt": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-static-copy": "catalog:vitepress1",
    "vitepress": "^1.6.4",
    "vue-check": "workspace:*",
    "wrangler": "catalog:"
  }
}
