{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "docs:preview": {
      "dependsOn": ["^docs:api", "build"],
      "cache": false,
      "persistent": true
    },
    "wrangler": {
      "dependsOn": ["^transit"],
      "cache": false
    },
    "wrangler:dev": {
      "dependsOn": ["^docs:api", "build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build", "^docs:api", "examples#build:embeds"],
      "env": ["VITE_GOOGLE_ANALYTICS_TRACKING_ID"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^docs:api"],
      "with": ["typecheck:vue"]
    },
    "docs": {
      "dependsOn": ["^build", "^docs:api", "examples#build:embeds"],
      "cache": false,
      "persistent": true
    },
    "typecheck:vue": {
      "dependsOn": ["^build"],
      "inputs": [
        ".vitepress/env.d.ts",
        ".vitepress/theme/components/*.vue",
        "tsconfig.json",
        "tsconfig.vue.json"
      ]
    }
  }
}
