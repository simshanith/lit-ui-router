{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "docs:preview": {
      "dependsOn": ["^docs:api", "build"],
      "cache": false,
      "persistent": true
    },
    "wrangler:dev": {
      "dependsOn": ["^docs:api", "build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build", "^docs:api", "examples#build:embeds"],
      "env": ["VITE_GOOGLE_ANALYTICS_TRACKING_ID"]
    },
    "typecheck": {
      // Overrides REPLACE root deps, so re-state ^transit: worker/tsconfig
      // reaches sample-app-routes and ui-router-server sources directly.
      "dependsOn": ["^build", "^docs:api", "^transit", "types:worker"],
      "with": ["typecheck:vue"]
    },
    "types:worker": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/wrangler.jsonc"],
      "outputs": ["worker/worker-configuration.d.ts"]
    },
    "docs": {
      "dependsOn": ["^build", "^docs:api", "examples#build:embeds"],
      "cache": false,
      "persistent": true
    },
    "typecheck:vue": {
      "dependsOn": ["^build"],
      "inputs": [
        ".vitepress/env.d.ts",
        ".vitepress/theme/components/*.vue",
        "tsconfig.json",
        "tsconfig.vue.json"
      ]
    }
  }
}
