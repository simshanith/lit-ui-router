{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "docs:preview": {
      "dependsOn": ["^docs:api", "build"],
      "cache": false,
      "persistent": true
    },
    "wrangler": {
      "dependsOn": ["^transit"],
      "cache": false
    },
    "wrangler:dev": {
      "dependsOn": ["^docs:api", "build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build", "^docs:api", "examples#build:embeds"],
      "env": ["VITE_GOOGLE_ANALYTICS_TRACKING_ID"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^docs:api"]
    },
    "docs": {
      "dependsOn": ["^build", "^docs:api", "examples#build:embeds"],
      "cache": false,
      "persistent": true
    }
  }
}
