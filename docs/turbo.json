{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "bundle:worker": {
      // --dry-run only bundles worker src (the script stubs an empty dist:
      // assets ship via the binding, never inside index.js), so docs content
      // can't affect the artifact; workspace deps ride the transit chain.
      "dependsOn": ["transit"],
      "inputs": [
        "package.json",
        "worker/**",
        "$TURBO_ROOT$/wrangler.jsonc",
        "$TURBO_ROOT$/pnpm-lock.yaml"
      ],
      "outputs": ["dist-worker-stats/**"]
    },
    "codecov:bundle": {
      // Upload-only: ships the (possibly cache-replayed) dry-run artifact.
      "dependsOn": ["bundle:worker"]
    },
    "docs:preview": {
      "dependsOn": ["^docs:api", "build"],
      "cache": false,
      "persistent": true
    },
    "wrangler:dev": {
      "dependsOn": ["^docs:api", "build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": [
        "^build",
        "^docs:api",
        "examples#build:embeds",
        "types:worker"
      ],
      "env": ["VITE_GOOGLE_ANALYTICS_TRACKING_ID"]
    },
    "typecheck": {
      "dependsOn": ["^build:types", "^docs:api"],
      "with": ["typecheck:vue", "typecheck:worker", "typecheck:worker:tests"]
    },
    "test": {
      // The worker contract tests run the worker module in node; workspace
      // sources resolve directly (no build), but the root task's src/**
      // inputs would miss worker/**, so over-approximate.
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "typecheck:worker": {
      "dependsOn": ["^build:types", "types:worker"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.base.json"]
    },
    "typecheck:worker:tests": {
      // The worker module rides into the test graph, so the generated
      // worker-configuration.d.ts must exist here too.
      "dependsOn": ["^build:types", "types:worker"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.base.json"]
    },
    "lint": {
      // Type-aware oxlint reads worker/tsconfig.json, which needs the d.ts.
      "dependsOn": ["^build:types", "types:worker"]
    },
    "types:worker": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/wrangler.jsonc"],
      "outputs": ["worker/worker-configuration.d.ts"]
    },
    "docs": {
      "dependsOn": ["^build", "^docs:api", "examples#build:embeds"],
      "cache": false,
      "persistent": true
    },
    "typecheck:vue": {
      "dependsOn": ["^build:types"],
      "inputs": [
        ".vitepress/env.d.ts",
        ".vitepress/theme/components/*.vue",
        "tsconfig.json",
        "tsconfig.vue.json"
      ]
    }
  }
}
