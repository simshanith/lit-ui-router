{
  "name": "lit-ui-router-mobx",
  "version": "0.3.4",
  "description": "MobX bindings for lit-ui-router: an observable router store and reaction-based Lit ReactiveControllers",
  "keywords": [
    "lit",
    "mobx",
    "reactive-controller",
    "routing",
    "spa",
    "state-management",
    "ui-router"
  ],
  "homepage": "https://github.com/simshanith/lit-ui-router/tree/main/packages/lit-ui-router-mobx",
  "bugs": {
    "url": "https://github.com/simshanith/lit-ui-router/issues"
  },
  "license": "MIT",
  "author": "Shane Daniel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simshanith/lit-ui-router.git",
    "directory": "packages/lit-ui-router-mobx"
  },
  "files": [
    "dist/**",
    "src/*.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:js": "oxc-emit-js",
    "build:types": "oxc-emit-dts",
    "changelog": "release-it --changelog --git.tagMatch=\"lit-ui-router-mobx@[0-9]*.[0-9]*.[0-9]*\"",
    "check:bundle": "check-bundle-inputs",
    "codecov:bundle": "upload-entry-bundles",
    "commit:changelog": "echo \"Release \\${version}\n\n$(pnpm --silent changelog)\"",
    "docs:api": "rimraf ../../docs/api/lit-ui-router-mobx && typedoc",
    "format": "oxfmt \"**/*.{ts,js,json,md}\"",
    "format:check": "oxfmt --check \"**/*.{ts,js,json,md}\"",
    "lint": "oxlint .",
    "test": "VITEST_BROWSER_API_PORT=63330 vitest run",
    "test:coverage": "VITEST_BROWSER_API_PORT=63335 vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:peer-floor": "node peer-floor-guard.ts && tsc -p tsconfig.peer-floor.json --noEmit",
    "typecheck:src": "tsc -p tsconfig.src.json --noEmit"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "catalog:",
    "@tools/bundle-probe": "workspace:*",
    "@tools/happy-dom": "workspace:*",
    "@tools/oxc-emit": "workspace:*",
    "@tools/typedoc-plugin-lit-ui-router": "workspace:*",
    "@types/node": "catalog:",
    "@uirouter/core": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "happy-dom": "catalog:",
    "lit": "catalog:",
    "lit-ui-router": "workspace:*",
    "lit-ui-router-floor": "catalog:peerFloor",
    "mobx": "catalog:",
    "oxfmt": "catalog:",
    "release-it": "catalog:",
    "rimraf": "catalog:",
    "typedoc": "catalog:",
    "typedoc-plugin-markdown": "catalog:",
    "typedoc-vitepress-theme": "catalog:",
    "typescript": "catalog:typescript6-compat",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@uirouter/core": "catalog:publishedPeer",
    "lit": "catalog:publishedPeer",
    "lit-ui-router": "catalog:publishedPeer",
    "mobx": "catalog:publishedPeer"
  }
}
