{
  // Tooling umbrella (IDE, tsgolint, typedoc): src + specs, no emit.
  // The build emits via tsconfig.build.json.
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/**/*",
    "peer-floor-guard.ts",
    "vitest.config.ts",
    "vitest.setup.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
