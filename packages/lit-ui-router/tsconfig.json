{
  // Tooling umbrella (IDE, tsgolint, typedoc): src + specs, no emit.
  // The build emits via tsconfig.build.json.
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    // Conformance is a shipped-src concern; specs are exempt (the second
    // typecheck pass below enforces it via tsconfig.build.json).
    "isolatedDeclarations": false,
    "types": ["vitest/globals"]
  },
  "include": ["src/**/*", "vitest.config.ts", "vitest.setup.ts"],
  "exclude": ["node_modules", "dist"]
}
