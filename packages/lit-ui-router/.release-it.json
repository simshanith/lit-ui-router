{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "commit": false,
    "tag": false,
    "tagName": "${npm.name}@${version}",
    "push": false,
    "requireUpstream": false
  },
  "github": {
    "release": false,
    "releaseName": "Release ${npm.name}@${version}",
    "autoGenerate": false
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          {
            "type": "feat",
            "section": "Features"
          },
          {
            "type": "fix",
            "section": "Bug Fixes"
          },
          {
            "type": "perf",
            "section": "Performance Improvements"
          },
          {
            "type": "revert",
            "section": "Reverts"
          },
          {
            "type": "build",
            "section": "Build System"
          }
        ]
      },
      "gitRawCommitsOpts": {
        "path": "."
      },
      "ignoreRecommendedBump": true,
      "writerOpts": {
        "headerPartial": ""
      }
    }
  }
}
