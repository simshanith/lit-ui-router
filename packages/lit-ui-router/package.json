{
  "name": "lit-ui-router",
  "version": "1.6.0",
  "description": "State-based routing for Lit",
  "homepage": "https://lit-ui-router.dev",
  "license": "MIT",
  "author": "Shane Daniel",
  "repository": {
    "type": "git",
    "url": "https://github.com/simshanith/lit-ui-router"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": [
    "**/ui-router.js",
    "**/ui-view.js"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:custom-elements": "cem analyze --outdir ./dist",
    "changelog": "release-it --changelog --git.tagMatch=\"lit-ui-router@[0-9]*.[0-9]*.[0-9]*\"",
    "commit:changelog": "echo \"Release \\${version}\n\n$(pnpm --silent changelog)\"",
    "docs:api": "rimraf ../../docs/api/reference && typedoc --defaultCategory other",
    "format": "oxfmt \"**/*.{ts,js,json,md}\"",
    "format:check": "oxfmt --check \"**/*.{ts,js,json,md}\"",
    "lint": "oxlint .",
    "test": "VITEST_BROWSER_API_PORT=63320 vitest run",
    "test:coverage": "VITEST_BROWSER_API_PORT=63325 vitest run --coverage --browser=chromium",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@uirouter/core": "catalog:publishedPeer",
    "lit": "catalog:publishedPeer"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "oxfmt": "catalog:",
    "playwright": "catalog:",
    "release-it": "catalog:",
    "rimraf": "catalog:",
    "typedoc": "catalog:",
    "typedoc-plugin-lit-ui-router": "workspace:*",
    "typedoc-plugin-markdown": "catalog:",
    "typedoc-vitepress-theme": "catalog:",
    "typescript": "catalog:ts6",
    "vitest": "catalog:"
  },
  "customElements": "dist/custom-elements.json"
}
