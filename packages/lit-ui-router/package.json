{
  "name": "lit-ui-router",
  "description": "State-based routing for Lit",
  "version": "1.3.0",
  "type": "module",
  "module": "./dist/index.js",
  "homepage": "https://lit-ui-router.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/simshanith/lit-ui-router"
  },
  "sideEffects": [
    "**/ui-router.js",
    "**/ui-view.js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc",
    "build:custom-elements": "cem analyze --outdir ./dist",
    "changelog": "release-it --changelog --git.tagMatch=\"lit-ui-router@[0-9]*.[0-9]*.[0-9]*\"",
    "commit:changelog": "echo \"Release \\${version}\n\n$(pnpm --silent changelog)\"",
    "docs:api": "rimraf ../../docs/api/reference && typedoc --defaultCategory other",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --browser=chromium"
  },
  "customElements": "dist/custom-elements.json",
  "dependencies": {
    "@uirouter/core": "catalog:publishedPeer",
    "lit": "catalog:publishedPeer"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "playwright": "catalog:",
    "prettier": "catalog:",
    "release-it": "catalog:",
    "rimraf": "catalog:",
    "typedoc": "catalog:",
    "typedoc-plugin-lit-ui-router": "workspace:*",
    "typedoc-plugin-markdown": "catalog:",
    "typedoc-vitepress-theme": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
