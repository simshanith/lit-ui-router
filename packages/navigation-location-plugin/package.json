{
  "name": "ui-router-navigation-location-plugin",
  "version": "0.2.1",
  "description": "UI Router Location Plugin for Navigation API",
  "keywords": [
    "location",
    "navigation-api",
    "plugin",
    "routing",
    "spa",
    "ui-router"
  ],
  "homepage": "https://github.com/simshanith/lit-ui-router/tree/main/packages/navigation-location-plugin",
  "bugs": {
    "url": "https://github.com/simshanith/lit-ui-router/issues"
  },
  "license": "MIT",
  "author": "Shane Daniel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simshanith/lit-ui-router.git",
    "directory": "packages/navigation-location-plugin"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "changelog": "release-it --changelog --git.tagMatch=\"ui-router-navigation-location-plugin@[0-9]*.[0-9]*.[0-9]*\"",
    "commit:changelog": "echo \"Release \\${version}\n\n$(pnpm --silent changelog)\"",
    "docs:api": "rimraf ../../docs/api/navigation-location-plugin && typedoc",
    "format": "oxfmt \"**/*.{ts,js,json,md}\"",
    "format:check": "oxfmt --check \"**/*.{ts,js,json,md}\"",
    "lint": "oxlint .",
    "test": "VITEST_BROWSER_API_PORT=63340 vitest run",
    "test:coverage": "VITEST_BROWSER_API_PORT=63345 vitest run --coverage --browser=chromium"
  },
  "devDependencies": {
    "@types/dom-navigation": "catalog:",
    "@uirouter/core": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "oxfmt": "catalog:",
    "playwright": "catalog:",
    "release-it": "catalog:",
    "rimraf": "catalog:",
    "typedoc": "catalog:",
    "typedoc-plugin-lit-ui-router": "workspace:*",
    "typedoc-plugin-markdown": "catalog:",
    "typedoc-vitepress-theme": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@uirouter/core": "catalog:publishedPeer"
  }
}
