{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "build:embeds": {
      "inputs": [
        "build-embeds.mjs",
        "*/index.html",
        "*/package.json",
        "*/package-lock.json",
        "*/src/**",
        "*/tsconfig.json",
        "*/vite.config.ts"
      ],
      "outputs": ["*/dist/**"]
    },
    "typecheck": {
      // The examples typecheck against the published lit-ui-router in their
      // own npm-ci node_modules, which build:embeds installs.
      "dependsOn": ["build:embeds"]
    }
  }
}
