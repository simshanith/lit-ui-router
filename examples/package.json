{
  "name": "examples",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:embeds": "node build-embeds.ts",
    "format": "oxfmt \"**/*.{ts,js,json,md,html}\"",
    "format:check": "oxfmt --check \"**/*.{ts,js,json,md,html}\"",
    "lint": "oxlint .",
    "typecheck": "concurrently --names helloworld,hellosolarsystem,hellogalaxy --prefix-colors auto \"pnpm run typecheck:helloworld\" \"pnpm run typecheck:hellosolarsystem\" \"pnpm run typecheck:hellogalaxy\"",
    "typecheck:hellogalaxy": "node build-embeds.ts --install hellogalaxy && tsc -p hellogalaxy",
    "typecheck:hellosolarsystem": "node build-embeds.ts --install hellosolarsystem && tsc -p hellosolarsystem",
    "typecheck:helloworld": "node build-embeds.ts --install helloworld && tsc -p helloworld"
  },
  "devDependencies": {
    "concurrently": "catalog:",
    "typescript": "catalog:"
  }
}
