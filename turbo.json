{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      // umbrella over own-package passes; no-ops where scripts are absent
      "dependsOn": ["^build", "build:js", "build:types"],
      "outputs": ["dist/**"]
    },
    "build:js": {
      "outputs": ["dist/**/*.js", "dist/**/*.js.map"]
    },
    "build:types": {
      // self-chain to build types transitively
      "dependsOn": ["^build:types"],
      "outputs": ["dist/**/*.d.ts", "dist/**/*.d.ts.map"]
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": ["src/**/*.ts", "vitest.config.ts", "cypress.config.ts"],
      "env": ["VITEST_BROWSER_API_PORT", "CI"],
      "passThroughEnv": ["WRANGLER_LOG"]
    },
    "@tools/dts-backtest#test": {
      "dependsOn": ["^build"],
      "inputs": ["fixtures/**", "run.ts", "tsconfig.fixture*.json"]
    },
    "test:coverage": {
      "dependsOn": ["^build", "^test:coverage"],
      "inputs": ["src/**/*.ts", "vitest.config.ts"],
      "env": ["VITEST_BROWSER_API_PORT", "CI"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "with": ["//#lint:root", "//#lint:package-json", "//#lint:workflows"],
      "dependsOn": ["^build"],
      "inputs": [
        "**/*.ts",
        "**/*.js",
        "$TURBO_ROOT$/.oxlintrc.json",
        "$TURBO_DEFAULT$"
      ]
    },
    "//#lint:root": {
      "inputs": ["examples/**/*.{ts,js}", ".oxlintrc.json", "$TURBO_DEFAULT$"]
    },
    "//#lint:package-json": {
      "inputs": [
        "**/package.json",
        "eslint.config.js",
        "pnpm-workspace.yaml",
        ".oxlintrc.json"
      ]
    },
    "//#lint:workflows": {
      "inputs": [
        ".github/**",
        "zizmor.yml",
        ".config/mise/config.toml",
        ".config/mise/mise.lock",
        "$TURBO_DEFAULT$"
      ]
    },
    "typecheck": {
      // ^build drops once every package is pass-split
      "dependsOn": ["^build", "^build:types"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.base.json"],
      "with": ["//#typecheck:root", "typecheck:src"]
    },
    "typecheck:src": {
      "dependsOn": ["^build", "^build:types"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.base.json"]
    },
    "typecheck:peer-floor": {
      // manual-only: not in ci — the floor pin can only reference published
      // versions, so gating would break atomic core-API + mobx-adoption PRs
      // floor comes from the catalog; the aliased package is pinned by the lockfile
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/pnpm-lock.yaml"
      ]
    },
    "//#typecheck:root": {
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "ci": {
      "dependsOn": [
        "build",
        "test",
        "test:coverage",
        "lint",
        "typecheck",
        "format:check",
        "codecov:bundle",
        "@tools/release#check:pack"
      ]
    },
    "codecov:bundle": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": ["CODECOV_TOKEN", "CI", "GITHUB_*"]
    },
    "format": {
      "with": ["//#format:root"],
      "inputs": [
        "**/*.{ts,js,mjs,cjs,json,jsonc,md,yml,yaml,html,vue}",
        ".oxfmtrc.json",
        "$TURBO_ROOT$/.oxfmtrc.json"
      ]
    },
    "format:check": {
      "with": ["//#format:check:root"],
      "inputs": [
        "**/*.{ts,js,mjs,cjs,json,jsonc,md,yml,yaml,html,vue}",
        ".oxfmtrc.json",
        "$TURBO_ROOT$/.oxfmtrc.json"
      ]
    },
    "//#format:root": {
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "//#format:check:root": {
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "e2e": {
      "dependsOn": ["^build", "^docs", "^e2e"],
      "cache": false,
      "persistent": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "docs": {
      "dependsOn": ["^build", "^docs:api"],
      "cache": false,
      "persistent": true
    },
    "docs:api": {
      "dependsOn": ["^build", "^docs:api"],
      "inputs": ["$TURBO_DEFAULT$"]
    }
  }
}
