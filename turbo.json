{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      // umbrella over own-package passes; no-ops where scripts are absent
      "dependsOn": ["^build", "build:js", "build:types"],
      "outputs": ["dist/**"]
    },
    "build:js": {
      "outputs": ["dist/**/*.js", "dist/**/*.js.map"]
    },
    "build:types": {
      // self-chain to build types transitively
      "dependsOn": ["^build:types"],
      "outputs": ["dist/**/*.d.ts", "dist/**/*.d.ts.map"]
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": [
        "src/**/*.ts",
        "vitest.config.ts",
        "vitest.setup.ts",
        "cypress.config.ts"
      ],
      "env": ["VITEST_BROWSER_API_PORT", "CI"],
      // CYPRESS_video: CI disables Cypress recording (build-test.yml);
      // strict env mode would scrub the override before it reaches Cypress.
      "passThroughEnv": ["WRANGLER_LOG", "CYPRESS_video"]
    },
    "@tools/dts-backtest#test": {
      "dependsOn": ["^build"],
      "inputs": ["fixtures/**", "run.ts", "tsconfig.fixture*.json"]
    },
    // Full TS version matrix; distinct task name = distinct cache key from
    // the current-leg-only #test above. Runs on main push, not the PR graph.
    "@tools/dts-backtest#test:matrix": {
      "dependsOn": ["^build"],
      "inputs": ["fixtures/**", "run.ts", "tsconfig.fixture*.json"]
    },
    "test:coverage": {
      "dependsOn": ["^build", "^test:coverage"],
      "inputs": ["src/**/*.ts", "vitest.config.ts", "vitest.setup.ts"],
      "env": ["VITEST_BROWSER_API_PORT", "CI"],
      "outputs": ["coverage/**"]
    },
    // Firefox+WebKit full-suite pass for the vitest packages; chromium
    // correctness rides test:coverage on PRs. Runs on main push, not the
    // PR graph.
    "test:engines": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "vitest.config.ts", "vitest.setup.ts"],
      "env": ["VITEST_BROWSER_API_PORT", "CI"]
    },
    "lint": {
      "with": [
        "//#lint:root",
        "//#lint:package-json",
        "//#lint:workflows",
        "//#check:patches"
      ],
      // type-aware oxlint resolves cross-package imports to dist d.ts only
      "dependsOn": ["^build:types"],
      "inputs": [
        "**/*.ts",
        "**/*.js",
        "$TURBO_ROOT$/.oxlintrc.json",
        "$TURBO_DEFAULT$"
      ]
    },
    "//#lint:root": {
      "inputs": [".oxlintrc.json", "$TURBO_DEFAULT$"]
    },
    "//#check:patches": {
      // pnpm-lock.yaml carries the patch hashes, so a dependency bump that
      // could rotate a patch target re-runs the check
      "inputs": [
        "check-patches.ts",
        "patches/**",
        "pnpm-workspace.yaml",
        "pnpm-lock.yaml",
        "tools/shared/src/**"
      ]
    },
    "//#lint:package-json": {
      "inputs": [
        "**/package.json",
        "eslint.config.ts",
        "eslint.repo-rules.ts",
        "pnpm-workspace.yaml",
        ".oxlintrc.json"
      ]
    },
    "//#lint:workflows": {
      // now also runs `taplo lint` over every .toml AND shellcheck over the repo
      // shell surface, so the key tracks the full TOML set + taplo's scoping
      // (.config/taplo.toml) + every tracked *.sh + the extensionless mise task
      // scripts (the taplo and shellcheck tasks) + both tool pins (mise.lock).
      // .config/mise/config.toml is subsumed by **/*.toml; mise.lock is not
      // (.lock, not .toml/.sh) so it stays explicit.
      "inputs": [
        ".github/**",
        "zizmor.yml",
        "**/*.toml",
        "**/*.sh",
        "!**/node_modules/**",
        "$TURBO_ROOT$/.config/taplo.toml",
        "$TURBO_ROOT$/.config/mise/tasks/**",
        ".config/mise/mise.lock",
        "$TURBO_DEFAULT$"
      ]
    },
    "typecheck": {
      // types come from build:types alone; JS emit stays off the typecheck path
      "dependsOn": ["^build:types"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.base.json"],
      "with": ["//#typecheck:root", "typecheck:src"]
    },
    "typecheck:src": {
      "dependsOn": ["^build:types"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.base.json"]
    },
    "typecheck:peer-floor": {
      // manual-only: not in ci — the floor pin can only reference published
      // versions, so gating would break atomic core-API + mobx-adoption PRs
      // floor comes from the catalog; the aliased package is pinned by the lockfile
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/pnpm-lock.yaml"
      ]
    },
    "//#typecheck:root": {
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "ci:pull_request": {
      "dependsOn": [
        "build",
        "test",
        "test:coverage",
        "lint",
        "typecheck",
        "format:check",
        "check:bundle",
        "@tools/release#check:exports"
      ]
    },
    "@tools/release#check:exports": {
      // packed exports/types resolve; needs shipped dist, re-run on any manifest edit
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/packages/*/package.json"]
    },
    "check:bundle": {
      "dependsOn": ["transit"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "ci:main": {
      // PR graph plus the main-only guards, scheduled by one turbo
      // invocation; future main-only guards join this dependsOn, not new
      // workflow steps.
      "dependsOn": [
        "ci:pull_request",
        "test:engines",
        "@tools/release#check:pack",
        "@tools/dts-backtest#test:matrix"
      ]
    },
    "ci": {
      // back-compat alias: `mise run ci` / `pnpm run ci` keep working
      "dependsOn": ["ci:pull_request"]
    },
    "codecov:bundle": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": ["CODECOV_TOKEN", "CI", "GITHUB_*"]
    },
    "format": {
      "with": ["//#format:root", "//#format:toml"],
      "inputs": [
        "**/*.{ts,js,mjs,cjs,json,jsonc,md,yml,yaml,html,vue}",
        ".oxfmtrc.json",
        "$TURBO_ROOT$/.oxfmtrc.json"
      ]
    },
    "format:check": {
      "with": ["//#format:check:root", "//#format:check:toml"],
      "inputs": [
        "**/*.{ts,js,mjs,cjs,json,jsonc,md,yml,yaml,html,vue}",
        ".oxfmtrc.json",
        "$TURBO_ROOT$/.oxfmtrc.json"
      ]
    },
    "//#format:root": {
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "//#format:check:root": {
      "inputs": ["$TURBO_DEFAULT$"]
    },
    // taplo owns .toml; separate root task so its cache key tracks only .toml
    // (plus the .taplo.toml scoping and taplo's pin), disjoint from oxfmt above.
    "//#format:toml": {
      "inputs": [
        "**/*.toml",
        "!**/node_modules/**",
        "$TURBO_ROOT$/.config/taplo.toml",
        "$TURBO_ROOT$/.config/mise/tasks/taplo",
        "$TURBO_ROOT$/.config/mise/mise.lock"
      ]
    },
    "//#format:check:toml": {
      "inputs": [
        "**/*.toml",
        "!**/node_modules/**",
        "$TURBO_ROOT$/.config/taplo.toml",
        "$TURBO_ROOT$/.config/mise/tasks/taplo",
        "$TURBO_ROOT$/.config/mise/mise.lock"
      ]
    },
    "e2e": {
      "dependsOn": ["^build", "^docs", "^e2e"],
      "cache": false,
      "persistent": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "docs": {
      "dependsOn": ["^build", "^docs:api"],
      "cache": false,
      "persistent": true
    },
    "docs:api": {
      "dependsOn": ["^build", "^docs:api"],
      "inputs": ["$TURBO_DEFAULT$"]
    }
  }
}
