{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "with": ["//#test:root"],
      "dependsOn": ["^test"],
      "inputs": ["src/**/*.ts", "vitest.config.ts", "cypress.config.ts"],
      "env": ["VITEST_BROWSER_API_PORT", "CI"],
      "passThroughEnv": ["WRANGLER_LOG"]
    },
    "dts-backtest#test": {
      "dependsOn": ["^build"],
      "inputs": ["fixtures/**", "run.ts", "tsconfig.fixture*.json"]
    },
    "test:coverage": {
      "dependsOn": ["^build", "^test:coverage"],
      "inputs": ["src/**/*.ts", "vitest.config.ts"],
      "env": ["VITEST_BROWSER_API_PORT", "CI"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "with": ["//#lint:root", "//#lint:package-json"],
      "dependsOn": ["^build"],
      "inputs": [
        "**/*.ts",
        "**/*.js",
        "$TURBO_ROOT$/.oxlintrc.json",
        "$TURBO_DEFAULT$"
      ]
    },
    "//#lint:root": {
      "inputs": ["examples/**/*.{ts,js}", ".oxlintrc.json", "$TURBO_DEFAULT$"]
    },
    "//#lint:package-json": {
      "inputs": ["**/package.json", "eslint.config.js"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.base.json"],
      "with": ["//#typecheck:root"]
    },
    "//#typecheck:root": {
      "inputs": [
        "scripts/**/*.ts",
        "examples/build-embeds.ts",
        "tools/dts-backtest/run.ts",
        "tools/vue-check/bin.ts",
        "tsconfig.json",
        "tsconfig.base.json"
      ]
    },
    "ci": {
      "dependsOn": [
        "build",
        "test",
        "test:coverage",
        "lint",
        "typecheck",
        "format:check",
        "codecov:bundle",
        "//#check:catalog",
        "//#check:pack"
      ]
    },
    "codecov:bundle": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": ["CODECOV_TOKEN", "CI", "GITHUB_*"]
    },
    "//#check:catalog": {
      "inputs": [
        "scripts/check-catalog.ts",
        "scripts/check-catalog.core.ts",
        "scripts/workspace.ts",
        "pnpm-workspace.yaml",
        "**/package.json"
      ]
    },
    "//#check:pack": {
      "inputs": [
        "scripts/check-pack.ts",
        "scripts/check-pack.core.ts",
        "scripts/check-catalog.core.ts",
        "scripts/workspace.ts",
        "pnpm-workspace.yaml",
        "**/package.json"
      ]
    },
    "//#test:root": {
      "inputs": ["scripts/**"]
    },
    "format": {
      "with": ["//#format:root"],
      "inputs": [
        "**/*.{ts,js,json,jsonc,md,yml,yaml,html,vue}",
        ".oxfmtrc.json"
      ]
    },
    "format:check": {
      "with": ["//#format:check:root"],
      "inputs": [
        "**/*.{ts,js,json,jsonc,md,yml,yaml,html,vue}",
        ".oxfmtrc.json"
      ]
    },
    "//#format:root": {
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "//#format:check:root": {
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "e2e": {
      "dependsOn": ["^build", "^docs", "^e2e"],
      "cache": false,
      "persistent": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "docs": {
      "dependsOn": ["^build", "^docs:api"],
      "cache": false,
      "persistent": true
    },
    "docs:api": {
      "dependsOn": ["^build", "^docs:api"],
      "cache": false
    }
  }
}
