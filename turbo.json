{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "with": ["//#test:root"],
      "dependsOn": ["^test"],
      "inputs": ["src/**/*.ts", "vitest.config.ts", "cypress.config.ts"],
      "env": ["VITEST_BROWSER_API_PORT", "CI"],
      "passThroughEnv": ["WRANGLER_LOG"]
    },
    "dts-backtest#test": {
      "dependsOn": ["^build"],
      "inputs": ["fixtures/**", "run.mjs", "tsconfig.fixture*.json"]
    },
    "test:coverage": {
      "dependsOn": ["^build", "^test:coverage"],
      "inputs": ["src/**/*.ts", "vitest.config.ts"],
      "env": ["VITEST_BROWSER_API_PORT", "CI"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "with": ["//#lint:root", "//#lint:package-json"],
      "dependsOn": ["^build"],
      "inputs": [
        "**/*.ts",
        "**/*.js",
        "$TURBO_ROOT$/.oxlintrc.json",
        "$TURBO_DEFAULT$"
      ]
    },
    "//#lint:root": {
      "inputs": ["examples/**/*.{ts,js}", ".oxlintrc.json", "$TURBO_DEFAULT$"]
    },
    "//#lint:package-json": {
      "inputs": ["**/package.json", "eslint.config.js"]
    },
    "ci": {
      "dependsOn": [
        "build",
        "test",
        "test:coverage",
        "lint",
        "format:check",
        "//#check:catalog",
        "//#check:pack"
      ]
    },
    "//#check:catalog": {
      "inputs": [
        "scripts/check-catalog.mjs",
        "scripts/check-catalog.core.mjs",
        "scripts/workspace.mjs",
        "pnpm-workspace.yaml",
        "**/package.json"
      ]
    },
    "//#check:pack": {
      "inputs": [
        "scripts/check-pack.mjs",
        "scripts/check-pack.core.mjs",
        "scripts/check-catalog.core.mjs",
        "scripts/workspace.mjs",
        "pnpm-workspace.yaml",
        "**/package.json"
      ]
    },
    "//#test:root": {
      "inputs": ["scripts/**"]
    },
    "format": {
      "with": ["//#format:root"],
      "inputs": ["**/*.{ts,js,json,jsonc,md}", ".prettierrc", ".prettierignore"]
    },
    "format:check": {
      "with": ["//#format:check:root"],
      "inputs": ["**/*.{ts,js,json,jsonc,md}", ".prettierrc", ".prettierignore"]
    },
    "//#format:root": {
      "inputs": [
        "*.{ts,js,json,jsonc,md}",
        "examples/**/*.{ts,js,json,jsonc,md}",
        ".prettierrc",
        ".prettierignore"
      ]
    },
    "//#format:check:root": {
      "inputs": [
        "*.{ts,js,json,jsonc,md}",
        "examples/**/*.{ts,js,json,jsonc,md}",
        ".prettierrc",
        ".prettierignore"
      ]
    },
    "e2e": {
      "dependsOn": ["^build", "^docs", "^e2e"],
      "cache": false,
      "persistent": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "docs": {
      "dependsOn": ["^build", "^docs:api"],
      "cache": false,
      "persistent": true
    },
    "docs:api": {
      "dependsOn": ["^build", "^docs:api"],
      "cache": false
    }
  }
}
