#!/usr/bin/env bash
#MISE description="Prompt for a secret on the terminal and write it to stdout (pipe only)"
#USAGE flag "--label <label>" help="Prompt text" default="Secret"
set -eu

# Refuse to put a secret in terminal scrollback: this task is only useful piped
# or captured. turbo_login calls it through command substitution.
[ -t 1 ] && {
  echo "read_secret: refusing to print a secret to a terminal; pipe me" >&2
  exit 1
}

exec 3<>/dev/tty || {
  echo "read_secret: no terminal to prompt on" >&2
  exit 1
}
printf '%s: ' "${usage_label:?}" >&3
stty -echo <&3
trap 'stty echo <&3' EXIT INT TERM
IFS= read -r secret <&3
stty echo <&3
trap - EXIT INT TERM
printf '\n' >&3
exec 3<&-
printf '%s' "$secret"
