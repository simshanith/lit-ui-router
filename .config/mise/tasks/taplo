#!/usr/bin/env bash
#MISE description="Run taplo over the tracked *.toml set (or given files)"
#USAGE arg "<cmd>" help="taplo subcommand: fmt | lint | check"
#USAGE flag "--check" help="fmt only: check formatting without writing"
#USAGE arg "[file]…" help="TOML files to target; default: every tracked *.toml"
#
# Shared taplo entrypoint. <cmd> passes through to taplo verbatim — note `taplo
# check` is schema validation, NOT `fmt --check` — with --check a fmt-only flag.
# Default files = `git ls-files -- '*.toml'`: the broad **/*.toml-minus-node_modules
# set with no directory walk and no pnpm install (taplo has no gitignore pruning,
# so a bare walk is ~14s and hits node_modules). Given files win, and explicit
# paths bypass taplo's walker too, so a single-file editor/pre-commit run is
# `mise run taplo fmt --check -- path/to/x.toml`. mise runs tasks from config_root,
# so no cd is needed.
set -euo pipefail

case "${usage_cmd:?}" in
  fmt | lint | check) ;;
  *) echo "taplo: unknown cmd '$usage_cmd' (fmt | lint | check)" >&2; exit 2 ;;
esac

set -- "$usage_cmd"
[ "${usage_check:-}" = "true" ] && set -- "$@" --check

files="${usage_file:-}"
[ -n "$files" ] || files=$(git ls-files -- '*.toml')
[ -n "$files" ] || exit 0

# unquoted $files: split the space/newline-joined list into args; TOML paths have no spaces
exec taplo "$@" $files
