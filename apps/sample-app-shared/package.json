{
  "name": "sample-app-shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./src/*",
    "./*.js": "./src/*.ts"
  },
  "scripts": {
    "format": "oxfmt \"**/*.{js,ts,json,md,css}\"",
    "format:check": "oxfmt --check \"**/*.{js,ts,json,md,css}\"",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@api-viewer/docs": "catalog:",
    "@uirouter/core": "catalog:",
    "@uirouter/dsr": "catalog:",
    "@uirouter/sticky-states": "catalog:",
    "@uirouter/visualizer": "catalog:",
    "lit": "catalog:",
    "lit-dialog": "catalog:",
    "lit-ui-router": "workspace:*",
    "lodash": "catalog:",
    "ui-router-navigation-location-plugin": "workspace:*"
  },
  "devDependencies": {
    "@types/dom-navigation": "catalog:",
    "@types/lodash": "catalog:",
    "oxfmt": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
