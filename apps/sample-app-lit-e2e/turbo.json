{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build", "^test"],
      "cache": false
    },
    "test:hash": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["CI"],
      "passThroughEnv": ["WRANGLER_LOG"]
    }
  }
}
