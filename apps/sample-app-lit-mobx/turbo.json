{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": [
        "CODECOV_TOKEN",
        "VITE_GOOGLE_ANALYTICS_TRACKING_ID",
        "VITE_SAMPLE_APP_BASE_URL",
        "VITE_SAMPLE_APP_PUSH_STATE"
      ],
      "passThroughEnv": ["GITHUB_*"],
      "inputs": ["$TURBO_DEFAULT$", "../sample-app-shared/**"]
    }
  }
}
