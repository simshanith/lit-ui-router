{
  "name": "sample-app-routes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#uirouter/*": {
      "node": "@uirouter/core/lib/*",
      "default": "@uirouter/core/lib-esm/*"
    }
  },
  "exports": {
    ".": "./src/routes.ts",
    "./matchers.js": "./src/matchers.ts"
  },
  "scripts": {
    "format": "oxfmt \"**/*.{ts,json,md}\"",
    "format:check": "oxfmt --check \"**/*.{ts,json,md}\"",
    "lint": "oxlint .",
    "test": "node --test \"test/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p test/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@uirouter/core": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "typescript": "catalog:"
  }
}
