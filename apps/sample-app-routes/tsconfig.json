{
  // These pure-data tables feed the docs worker and any server runtime. We
  // consume ui-router-server as workspace SOURCE, so tsc compiles its
  // implementation here too — and that uses setTimeout/URLSearchParams, which
  // @types/node (a devDep, erased) supplies. Neutrality is no longer `types:
  // []`-enforced; the no-restricted-globals lint (.oxlintrc.json) keeps this
  // src off node-only APIs, same as ui-router-server.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
