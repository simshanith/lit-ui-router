{
  // Runtime-neutral: no DOM, node, or workers types — these tables feed the
  // docs worker and any future server runtime, and the compiler enforces it.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "lib": ["ES2022"],
    "types": []
  },
  // ui-router-server's sources enter this program through imports only, so
  // its ambient runtime-neutrality shims (never imported) must be included
  // explicitly or URLSearchParams/setTimeout are TS2304s here.
  "include": ["src/**/*", "../../packages/ui-router-server/src/globals.d.ts"]
}
