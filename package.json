{
  "name": "lit-ui-router-turborepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check:catalog": "node scripts/check-catalog.ts",
    "check:pack": "node scripts/check-pack.ts",
    "check:workers-builds": "node scripts/workers-builds-triggers.ts",
    "ci": "turbo run ci",
    "dev": "turbo run dev",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "format:check:root": "oxfmt --check \"*.{md,ts,js,json,jsonc,yml,yaml}\" \"!pnpm-lock.yaml\" \"!apps/**\" \"!docs/**\" \"!examples/**\" \"!packages/**\" \"!tools/**\"",
    "format:root": "oxfmt \"*.{md,ts,js,json,jsonc,yml,yaml}\" \"!pnpm-lock.yaml\" \"!apps/**\" \"!docs/**\" \"!examples/**\" \"!packages/**\" \"!tools/**\"",
    "lint": "turbo run lint",
    "lint:package-json": "eslint --format tap \"**/package.json\"",
    "lint:root": "oxlint --ignore-pattern apps --ignore-pattern tools --ignore-pattern docs --ignore-pattern packages --ignore-pattern examples .",
    "lint:workflows": "mise exec -- actionlint",
    "test:coverage": "turbo run test:coverage",
    "test:root": "node --test \"scripts/**/*.test.ts\"",
    "typecheck": "turbo run typecheck",
    "typecheck:root": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@codecov/bundle-analyzer": "catalog:",
    "@pnpm/fs.find-packages": "catalog:",
    "@pnpm/workspace.read-manifest": "catalog:",
    "@types/node": "catalog:",
    "cypress": "catalog:",
    "eslint": "^10.6.0",
    "eslint-formatter-tap": "^9.0.1",
    "eslint-plugin-package-json": "^1.5.0",
    "eslint-plugin-turbo": "^2.10.4",
    "jsonc-parser": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "pnpm": "^11.10.0",
    "turbo": "^2.10.4",
    "typescript": "catalog:",
    "vite": "catalog:",
    "wrangler": "catalog:"
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "packageManager": "pnpm@11.10.0"
}
